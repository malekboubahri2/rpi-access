# rpi-access environment overrides (optional)
# Copy to .env for local development. NEVER commit .env.

# Run portal in dev mode (no AP setup, no privileged calls)
RPI_ACCESS_DEV=0

# Override config file path
RPI_ACCESS_CONFIG=/etc/rpi-access/rpi-access.conf

# Override log level (DEBUG, INFO, WARNING, ERROR)
RPI_ACCESS_LOG_LEVEL=INFO

# Flask secret key override (otherwise read from config.secret_key_file)
# RPI_ACCESS_SECRET_KEY=

# Master key for credentials encryption (base64-encoded Fernet key, 32 bytes)
# Generated automatically by setup.sh if absent.
# RPI_ACCESS_MASTER_KEY=
