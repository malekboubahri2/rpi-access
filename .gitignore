# rpi-access - .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs / runtime
*.log
logs/
/var/log/rpi-access/
*.pid
*.sock

# Local config & secrets
config/local.conf
config/*.local.*
.env
.env.*
!.env.example
secrets/
credentials.json
*.pem
*.key

# OS / build artifacts
*.tar.gz
*.zip
node_modules/

# rpi-access runtime state
runtime/
state.json
/srv/rpi-access/state/

# Claude Code agent local-only files (rules under .claude/rule/ ARE checked in)
.claude/settings.local.json
.claude/*.local.json
